<Window x:Class="TwistingMachine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:TwistingMachine.Views"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000"
        WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Background="#0066CC">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="HACNT" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">📊</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">⚙️</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">📋</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">🔧</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">📈</Button>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Width="20" Height="20" Background="Transparent" BorderBrush="Transparent" Foreground="White" Command="{Binding MinimizeCommand}">_</Button>
                <Button Width="20" Height="20" Background="Transparent" BorderBrush="Transparent" Foreground="White" Command="{Binding CloseCommand}">X</Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="220"/>
                <RowDefinition Height="450"/>
                
            </Grid.RowDefinitions>

            <!-- 第一行：缩略图 -->
            <GroupBox Grid.Row="0" Header="缩略图" BorderBrush="Gray" BorderThickness="1" Margin="5">
                <Grid>
                    <Canvas  Margin="-400,0,0,100" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- 线缆绞合示意图 -->
                        <Path Data="{Binding Wire1Path}" Stroke="{Binding Wire1Color}" StrokeThickness="4"/>
                        <Path Data="{Binding Wire2Path}" Stroke="{Binding Wire2Color}" StrokeThickness="4"/>
                        <Rectangle Canvas.Left="160" Canvas.Top="25" Width="10" Height="40" Fill="Black"/>
                        <Path Data="{Binding Wire1Path}" Stroke="{Binding Wire1Color}" StrokeThickness="4"/>
                        <Path Data="{Binding Wire2Path}" Stroke="{Binding Wire2Color}" StrokeThickness="4"/>
                        <Rectangle Canvas.Left="315" Canvas.Top="25" Width="10" Height="40" Fill="Black"/>
                        <Path Data="{Binding Wire1Path}" Stroke="{Binding Wire1Color}" StrokeThickness="4"/>
                        <Path Data="{Binding Wire2Path}" Stroke="{Binding Wire2Color}" StrokeThickness="4"/>
                        <TextBlock Canvas.Left="260" Canvas.Top="5" Text="3500"/>
                        <TextBlock Canvas.Left="90" Canvas.Top="60" Text="35"/>
                        <TextBlock Canvas.Left="260" Canvas.Top="60" Text="35"/>
                        <TextBlock Canvas.Left="430" Canvas.Top="60" Text="35"/>
                    </Canvas>
                </Grid>
            </GroupBox>

            <!-- 第二行：当前参数和右侧操作区 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- 当前参数区域 -->
                <GroupBox Grid.Column="0" Header="当前参数" BorderBrush="Gray" BorderThickness="1" Margin="5">

                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition/>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- 第一行 -->
                        <TextBlock Grid.Column="0" Text="胶带模式:" VerticalAlignment="Center" FontSize="16"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Width="300" Height="35" FontSize="16" HorizontalAlignment="Left">
                            <ComboBoxItem Content="选项1"/>
                            <ComboBoxItem Content="选项2"/>
                            <ComboBoxItem Content="选项3"/>
                        </ComboBox>
                        <TextBlock Grid.Column="3" Text="配方名称：" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2" Width="300" Height="35" HorizontalAlignment="Left" Text="{Binding RecipeName}" FontSize="16"/>

                        <!-- 第二行 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="线芯面积" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <TextBox Width="50" Text="{Binding CoreArea}" FontSize="16"/>
                            <TextBlock Text="mm²" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="左端开口" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding LeftEndOpening}" FontSize="16"/>
                            <TextBlock Text="mm" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="线前长度" VerticalAlignment="Center" Grid.ColumnSpan="2" FontSize="16"/>
                        <StackPanel Grid.Row="1" Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding WireFrontLength}" FontSize="16"/>
                            <TextBlock Text="mm" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>

                        <!-- 第三行 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="导线外径" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding WireOuterDiameter}" FontSize="16"/>
                            <TextBlock Text="mm" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="右端开口" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding RightEndOpening}" FontSize="16"/>
                            <TextBlock Text="mm" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="4" Text="大拉气压" VerticalAlignment="Center" Grid.ColumnSpan="2" FontSize="16"/>
                        <StackPanel Grid.Row="2" Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding LargePullPressure}" FontSize="16"/>
                            <TextBlock Text="Mpa" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>

                        <!-- 第四行 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="绞后长度" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding TwistedLength}" FontSize="16"/>
                            <TextBlock Text="mm" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="过绞合量" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="3" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding OverTwistAmount}" FontSize="16"/>
                            <TextBlock Text="%" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="4" Text="小拉气压" VerticalAlignment="Center" Grid.ColumnSpan="2" FontSize="16"/>
                        <StackPanel Grid.Row="3" Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding SmallPullPressure}" FontSize="16"/>
                            <TextBlock Text="Mpa" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>

                        <!-- 第五行 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="绞合节距" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding TwistPitch}" FontSize="16"/>
                            <TextBlock Text="mm" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="绞线缆数" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="4" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding TwistWireCount}" FontSize="16"/>
                            <TextBlock Text="根" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="4" Grid.Column="4" Text="修正系数" VerticalAlignment="Center" Grid.ColumnSpan="2" FontSize="16"/>
                        <TextBox Grid.Row="4" Grid.Column="6" HorizontalAlignment="Left" Width="50" Height="30" Text="{Binding CorrectionFactor}" Margin="0,0,0,0" FontSize="16"/>

                        <!-- 第六行 -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="节距补偿" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Width="50" Text="{Binding PitchCompensation}" FontSize="16"/>
                            <TextBlock Text="mm" Margin="5,0,0,0" FontSize="16"/>
                        </StackPanel>
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="绞合方向" VerticalAlignment="Center" FontSize="16"/>
                        <ComboBox Grid.Row="5" Grid.Column="3" Width="100" Height="30" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="0,6,100,-6" SelectedIndex="0" FontSize="16">
                            <ComboBoxItem Content="正"/>
                            <ComboBoxItem Content="反"/>
                        </ComboBox>

                        <!--第七行-->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="设定生产数量：" VerticalAlignment="Center" Grid.ColumnSpan="2" FontSize="16"/>
                        <TextBox Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left" Width="100" Height="30" Text="{Binding CorrectionFactor}" Margin="0,0,0,0" FontSize="16"/>

                    </Grid>
                </GroupBox>

                <!-- 右侧操作区 -->
                <Grid Grid.Column="1" Margin="5,20,5,20">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <!-- 按钮区域 -->
                    <Button Grid.Row="0" Margin="5" Width="200" Height="60" Content="松开夹爪" Background="Blue" Foreground="White" Command="{Binding LoosenJawsCommand}"/>
                    <Button Grid.Row="1" Margin="5" Width="200" Height="60" Content="重置" Background="Green" Foreground="White" Command="{Binding ResetCommand}"/>
                    <Button Grid.Row="2" Margin="5" Width="200" Height="60" Content="上胶带" Background="Red" Foreground="White" Command="{Binding ApplyTapeCommand}"/>

                    <!-- 前后选择区 -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="前" Margin="0,0,0,10" FontSize="16"/>
                            <TextBlock Text="后" Margin="0,10,0,0" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor1}"/>
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor2}"/>
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor3}"/>
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor4}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor5}"/>
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor6}"/>
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor7}"/>
                                <Rectangle Width="40" Height="40" Margin="5" Fill="{Binding FrontBackColor8}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

        </Grid>
        
        <!--操作和状态栏-->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <!-- 第一行：底部操作按钮 -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="复位" Width="100" Height="40" Margin="20,0,0,0"/>
                    <TextBlock Text="当前生产数量: 0" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    <Button Content="清零" Width="100" Height="40" Margin="20,0,0,0"/>
                    <Button Content="终止工单" Width="100" Height="40" Margin="20,0,0,0"/>
                    <Button Content="报警详情—>" Width="100" Height="40" Margin="20,0,0,0"/>
                </StackPanel>
            </Grid>

            <!--第二行：状态栏-->
            <Grid Grid.Row="1" Background="LightGray">
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="连接状态: 正常" Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="设备状态: 正常"  Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="MES状态: 正常"  Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="权限等级: 管理员"  Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="当前配方: AAA"  Margin="0,0,20,0" FontSize="16"/>
                </StackPanel>
            </Grid>

            <!--第三行：报警信息-->
            <Grid Grid.Row="2" Margin="0,2,0,0" Background="LightGray">

            </Grid>

            <!--第四行：服务热线：**********-->
            <Grid Grid.Row="3" Background="LightGray" Margin="0,2,0,0">
                <TextBlock Text="服务热线：000 000 000 000 *年*月*日 **有限公司"  FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0"></TextBlock>
            </Grid>
        </Grid>
    </Grid>
</Window>
