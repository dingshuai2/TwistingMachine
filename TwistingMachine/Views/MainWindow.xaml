<Window x:Class="TwistingMachine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:viewModels="clr-namespace:TwistingMachine.ViewModels"
        xmlns:views="clr-namespace:TwistingMachine.Views"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000"
        WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized">
    <Window.Resources>
        <!-- 页面数据模板 -->
        <DataTemplate DataType="{x:Type viewModels:ProductionViewModel}">
            <views:ProductionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SampleProductionViewModel}">
            <views:SampleProductionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:DebugViewModel}">
            <views:DebugView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:IOStatusViewModel}">
            <views:IOStatusView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:RecipeViewModel}">
            <views:RecipeView/>
        </DataTemplate>

        <!-- TabItem 样式：左侧导航按钮 -->
        <Style TargetType="TabItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0066CC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabControl 模板：把选项卡放左边 -->
        <ControlTemplate x:Key="LeftTabControlTemplate" TargetType="TabControl">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 选项卡头区域（左侧） -->
                <StackPanel Grid.Column="0" Background="#E0E0E0" Margin="0" IsItemsHost="True"/>

                <!-- 内容显示区域（右侧） -->
                <Border Grid.Column="1" Background="White" Margin="2,0,0,0">
                    <ContentPresenter ContentSource="SelectedContent"/>
                </Border>
            </Grid>
        </ControlTemplate>

        <!-- TabControl 样式：应用左侧模板 -->
        <Style TargetType="TabControl">
            <Setter Property="Template" Value="{StaticResource LeftTabControlTemplate}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="670"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Background="#0066CC">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="HACNT" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">📊</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">⚙️</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">📋</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">🔧</Button>
                <Button Width="30" Height="30" Background="Transparent" BorderBrush="Transparent" Foreground="White">📈</Button>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Width="20" Height="20" Background="Transparent" BorderBrush="Transparent" Foreground="White" Command="{Binding MinimizeCommand}">_</Button>
                <Button Width="20" Height="20" Background="Transparent" BorderBrush="Transparent" Foreground="White" Command="{Binding CloseCommand}">X</Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区：使用 TabControl -->
        <TabControl Grid.Row="1" Margin="0"
                    SelectedItem="{Binding CurrentViewModel}"
                    ItemsSource="{Binding PageViewModels}">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Header" Value="{Binding Title}"/>
                </Style>
            </TabControl.ItemContainerStyle>
        </TabControl>

        <!--操作和状态栏-->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <!-- 第一行：底部操作按钮 -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="复位" Width="100" Height="40" Margin="20,0,0,0"/>
                    <TextBlock Text="当前生产数量: 0" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    <Button Content="清零" Width="100" Height="40" Margin="20,0,0,0"/>
                    <Button Content="终止工单" Width="100" Height="40" Margin="20,0,0,0"/>
                    <Button Content="报警详情—>" Width="100" Height="40" Margin="20,0,0,0"/>
                </StackPanel>
            </Grid>

            <!--第二行：状态栏-->
            <Grid Grid.Row="1" Background="LightGray">
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="连接状态: 正常" Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="设备状态: 正常"  Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="MES状态: 正常"  Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="权限等级: 管理员"  Margin="0,0,20,0" FontSize="16"/>
                    <TextBlock Text="当前配方: AAA"  Margin="0,0,20,0" FontSize="16"/>
                </StackPanel>
            </Grid>

            <!--第三行：报警信息-->
            <Grid Grid.Row="2" Margin="0,2,0,0" Background="LightGray">

            </Grid>

            <!--第四行：服务热线-->
            <Grid Grid.Row="3" Background="LightGray" Margin="0,2,0,0">
                <TextBlock Text="服务热线：000 000 000 000 | 2026年03月06日 | XX智能设备有限公司"  FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
