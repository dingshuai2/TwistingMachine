<Controls:MetroWindow x:Class="TwistingMachine.Dialogs.TestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
        Title="测试弹窗"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="这是一个测试弹窗" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="弹窗内容：" Margin="0,0,0,10"/>
            <TextBox Width="300" Height="100" Text="请输入内容..." TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Width="80" Height="30" Margin="0,0,10,0"/>
                <Button Content="确定" Width="80" Height="30" Background="#0066CC" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
